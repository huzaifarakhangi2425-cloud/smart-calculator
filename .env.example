# OAuth / Google Sign-In
# Create these in Google Cloud Console
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# IMPORTANT:
# Set callback URL in Google console exactly like this (adjust domain/port)
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# Session secret (change to strong random string)
SESSION_SECRET=change-me-to-a-very-long-random-string

